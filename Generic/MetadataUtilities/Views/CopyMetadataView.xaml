<UserControl x:Class="MetadataUtilities.Views.CopyMetadataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:MetadataUtilities.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:CopyMetadataViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="450">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MetadataUtilities;component/Shared/Controls/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel Margin="15"
               d:Background="AliceBlue"
               FocusManager.FocusedElement="{Binding ElementName=LvConfig}">
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Bottom"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center">
            <Button Content="{DynamicResource LOCOKLabel}"
                    d:Content="OK"
                    Style="{StaticResource BottomButton}"
                    d:Style="{StaticResource KNARZBottomButton}"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}" />
            <Button Content="{DynamicResource LOCCancelLabel}"
                    d:Content="Cancel"
                    Style="{StaticResource BottomButton}"
                    d:Style="{StaticResource KNARZBottomButton}"
                    IsCancel="True" />
        </StackPanel>
        <ListView Name="LvConfig"
                  ItemsSource="{Binding CopyDataSet.Fields}"
                  DockPanel.Dock="Top"
                  VerticalContentAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="Auto">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource LOCTypeLabel}"
                                               d:Text="Type"
                                               Margin="5" />
                                    <Button FontFamily="Wingdings"
                                            FontSize="18"
                                            Content="þ"
                                            Command="{Binding DataContext.CheckAllCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Margin="5,0"
                                            Padding="5" />
                                    <Button FontFamily="Wingdings"
                                            FontSize="18"
                                            Content=""
                                            Command="{Binding DataContext.UnCheckAllCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Padding="5" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding CopyData, UpdateSourceTrigger=PropertyChanged}"
                                          Content="{Binding Label}"
                                          Margin="0,3,0,3" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="Auto">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource LOCMetadataUtilitiesDialogReplace}"
                                               d:Text="Replace"
                                               Margin="5" />
                                    <Button FontFamily="Wingdings"
                                            FontSize="18"
                                            Content="þ"
                                            Command="{Binding DataContext.CheckAllReplaceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Margin="5,0"
                                            Padding="5" />
                                    <Button FontFamily="Wingdings"
                                            FontSize="18"
                                            Content=""
                                            Command="{Binding DataContext.UnCheckAllReplaceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Padding="5" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding ReplaceData, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource KNARZGridCheckBox}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="Auto">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource LOCMetadataUtilitiesDialogOnlyIfEmpty}"
                                               d:Text="Only if empty"
                                               Margin="5" />
                                    <Button FontFamily="Wingdings"
                                            FontSize="18"
                                            Content="þ"
                                            Command="{Binding DataContext.CheckAllEmptyCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Margin="5,0"
                                            Padding="5" />
                                    <Button FontFamily="Wingdings"
                                            FontSize="18"
                                            Content=""
                                            Command="{Binding DataContext.UnCheckAllEmptyCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Padding="5" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding OnlyIfEmpty, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource KNARZGridCheckBox}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>