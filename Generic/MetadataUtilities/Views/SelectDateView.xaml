<UserControl x:Class="MetadataUtilities.Views.SelectDateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DataContext="{d:DesignInstance Type=viewModels:SelectIntViewModel}"
             xmlns:viewModels="clr-namespace:MetadataUtilities.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MetadataUtilities;component/Shared/Controls/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel FocusManager.FocusedElement="{Binding ElementName=DateValue}"
               Margin="15"
               d:Background="AliceBlue">
        <DatePicker Name="DateValue"
                    DockPanel.Dock="Top"
                    SelectedDate="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center">
            <Button Content="{DynamicResource LOCOKLabel}"
                    d:Content="OK"
                    IsDefault="True"
                    Style="{StaticResource BottomButton}"
                    d:Style="{StaticResource KNARZBottomButton}"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}" />
            <Button Content="{DynamicResource LOCCancelLabel}"
                    d:Content="Cancel"
                    IsCancel="True"
                    Style="{StaticResource BottomButton}"
                    d:Style="{StaticResource KNARZBottomButton}" />
        </StackPanel>
    </DockPanel>
</UserControl>