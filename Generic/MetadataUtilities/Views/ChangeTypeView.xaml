<UserControl x:Class="MetadataUtilities.Views.ChangeTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DataContext="{d:DesignInstance Type=viewModels:ChangeTypeViewModel}"
             xmlns:viewModels="clr-namespace:MetadataUtilities.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="140"
             d:DesignWidth="400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MetadataUtilities;component/Shared/Controls/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel Margin="15"
               FocusManager.FocusedElement="{Binding ElementName=txtName}"
               d:Background="AliceBlue">
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Top"
                    HorizontalAlignment="Left">
            <Label Content="{DynamicResource LOCMetadataUtilitiesDialogSelectNewType}"
                   d:Content="Select new type" />
            <ComboBox SelectedValue="{Binding NewType}"
                      ItemsSource="{Binding FieldValuePairs}"
                      SelectedValuePath="Key"
                      DisplayMemberPath="Value"
                      Margin="10,0,0,0"
                      Width="250" />
        </StackPanel>
        <CheckBox DockPanel.Dock="Top"
                  IsChecked="{Binding SaveAsRule}"
                  Content="{DynamicResource LOCMetadataUtilitiesDialogSaveAsRule}"
                  d:Content="Save as merge rule"
                  Margin="0,10,0,0" />
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">
            <Button Content="{DynamicResource LOCOKLabel}"
                    d:Content="OK"
                    Style="{StaticResource BottomButton}"
                    d:Style="{StaticResource KNARZBottomButton}"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}" />
            <Button Content="{DynamicResource LOCCancelLabel}"
                    d:Content="Cancel"
                    Style="{StaticResource BottomButton}"
                    d:Style="{StaticResource KNARZBottomButton}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True" />
        </StackPanel>
    </DockPanel>
</UserControl>