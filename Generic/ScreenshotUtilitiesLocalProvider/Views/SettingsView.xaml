<UserControl x:Class="ScreenshotUtilitiesLocalProvider.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ScreenshotUtilitiesLocalProvider.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <d:ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Localization/LocSource.xaml" />
                <ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Shared/Controls/CommonStyles.xaml" />
                <ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Controls/GameProfileTemplate.xaml" />
                <ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Controls/FolderConfigTemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid HorizontalAlignment="Stretch"
          Margin="15"
          x:Name="ConfigDock"
          d:Background="LightGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Grid.Row="0"
                   Margin="0, 0, 0, 15"
                   Style="{StaticResource SettingsDescription}"
                   Text="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigDescription}" />

        <ListBox Name="GridGameProfiles"
                 Grid.Column="0"
                 Grid.Row="1"
                 SelectionMode="Single"
                 Width="Auto"
                 MaxWidth="500"
                 MinWidth="100"
                 ItemsSource="{Binding Settings.GameProfiles}"
                 ItemTemplate="{StaticResource GameProfileTemplate}"
                 SelectedItem="{Binding SelectedGameProfile}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem"
                       BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Margin"
                            Value="5" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Button Command="{Binding AddGameProfileCommand}"
                Grid.Column="0"
                Grid.Row="2"
                Margin="0,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                MinHeight="40">
            <Button.Content>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xF101;"
                               FontFamily="{StaticResource KNARZIconFont}"
                               FontSize="{StaticResource FontSizeLarger}"
                               Margin="0, 0, 10, 0" />
                    <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonAddGame}"
                               Foreground="{StaticResource GlyphBrush}" />
                </StackPanel>
            </Button.Content>
        </Button>

        <ListBox Name="GridFolderConfigs"
                 Grid.Column="1"
                 Grid.Row="1"
                 Margin="10, 0, 0, 0"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemsSource="{Binding SelectedGameProfile.FolderConfigs}"
                 ItemTemplate="{StaticResource FolderConfigTemplate}"
                 SelectedItem="{Binding SelectedFolderConfig}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem"
                       BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Margin"
                            Value="5" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <ItemsControl ItemsSource="{Binding CommonConfigs}"
                      Grid.Column="1"
                      Grid.Row="2">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding Path=DataContext.AddFolderConfigCommand, ElementName=ConfigDock}"
                            CommandParameter="{Binding}"
                            Margin="10, 10, 0, 0"
                            MinHeight="40">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}"
                                           Foreground="{Binding IconBrush}"
                                           FontFamily="{StaticResource KNARZIconFont}"
                                           FontSize="{StaticResource FontSizeLarger}"
                                           Margin="0, 0, 10, 0" />
                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>