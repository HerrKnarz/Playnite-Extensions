<UserControl x:Class="ScreenshotUtilitiesLocalProvider.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <d:ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Localization/LocSource.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel Margin="10"
               d:Background="LightGray">
        <TextBlock DockPanel.Dock="Top"
                   TextWrapping="Wrap"
                   Text="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigDescription}" />
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Bottom"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left">
            <Button Content="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonAdd}"
                    Command="{Binding AddFolderConfigCommand}" />
            <Button Content="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonSort}"
                    Margin="10,0,0,0"
                    Command="{Binding SortFolderConfigsCommand}" />
        </StackPanel>
        <ListView Name="GridFolderConfigs"
                  SelectionMode="Single"
                  Margin="0,10,0,0"
                  DockPanel.Dock="Top"
                  ItemsSource="{Binding Settings.FolderConfigs}"
                  SelectedItem="{Binding SelectedItem}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="Auto"
                                    Header="{DynamicResource LOCEnabledTitle}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Active, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,-15,0"
                                          HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="Auto"
                                    Header="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigName}"
                                    DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Width="Auto"
                                    Header="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigPath}"
                                    DisplayMemberBinding="{Binding Path}" />
                    <GridViewColumn Width="Auto"
                                    Header="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigFileMask}"
                                    DisplayMemberBinding="{Binding FileMask}" />
                    <GridViewColumn Width="Auto">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="&#xec55;"
                                            FontFamily="{DynamicResource FontIcoFont}"
                                            Margin="0,5,0,5"
                                            ToolTip="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonEdit}"
                                            Command="{Binding Path=DataContext.EditFolderConfigCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListView}}}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=Content}" />
                                    <Button Content="&#xec53;"
                                            FontFamily="{DynamicResource FontIcoFont}"
                                            Margin="10,5,0,5"
                                            ToolTip="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonRemove}"
                                            Command="{Binding Path=DataContext.RemoveFolderConfigCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListView}}}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=Content}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>