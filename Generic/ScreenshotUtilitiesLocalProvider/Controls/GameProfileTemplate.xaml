<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:converters="clr-namespace:KNARZhelper.Controls"
                    mc:Ignorable="d">
    <DataTemplate x:Key="GameProfileTemplate">
        <DataTemplate.Resources>
            <ResourceDictionary>
                <converters:GameToIconConverter x:Key="GameToIconConverter" />

                <Style TargetType="TextBlock">
                    <Setter Property="Foreground"
                            Value="{DynamicResource TextBrush}"
                            d:Value="{DynamicResource KNARZDummyBrushBlack}" />
                    <Setter Property="VerticalAlignment"
                            Value="Top" />
                    <Setter Property="TextWrapping"
                            Value="Wrap" />
                </Style>

                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Shared/Controls/CommonStyles.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </DataTemplate.Resources>
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Image Grid.Row="0"
                   Grid.Column="0"
                   Grid.RowSpan="3"
                   Source="{Binding Game, Converter={StaticResource GameToIconConverter}}"
                   RenderOptions.BitmapScalingMode="Fant"
                   Visibility="{Binding HiddenOnDefault}"
                   Stretch="Uniform"
                   Margin="0, 0, 10, 0"
                   Height="64"
                   Width="64" />

            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       FontSize="{DynamicResource FontSizeLarge}"
                       d:FontSize="16"
                       Text="{Binding Game.Name}"
                       d:Text="Name" />

            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Visibility="{Binding HiddenOnDefault}"
                       Text="{Binding Game.Source}"
                       d:Text="Library" />

            <CheckBox Grid.Row="2"
                      Grid.Column="1"
                      Margin="0, 5, 0, 5"
                      Content="Override global configs"
                      Visibility="{Binding HiddenOnDefault}"
                      IsChecked="{Binding OverrideGlobalConfigs}"
                      HorizontalAlignment="Left" />

            <StackPanel Grid.Column="2"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Margin="15, 0, 0, 0">
                <Button Content="&#xec3e;"
                        Style="{DynamicResource KNARZIconButton}"
                        VerticalAlignment="Top"
                        ToolTip="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonAdd}"
                        d:ToolTip=""
                        Command="{Binding Path=DataContext.AddFolderConfigCommand, ElementName=ConfigDock}"
                        CommandParameter="{Binding}" />
                <Button Content="&#xec53;"
                        Style="{DynamicResource KNARZIconButton}"
                        VerticalAlignment="Top"
                        Margin="0, 10, 0, 0"
                        ToolTip="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonRemove}"
                        d:ToolTip=""
                        Visibility="{Binding HiddenOnDefault}"
                        Command="{Binding Path=DataContext.RemoveGameProfileCommand, ElementName=ConfigDock}"
                        CommandParameter="{Binding}" />
            </StackPanel>
        </Grid>
    </DataTemplate>
</ResourceDictionary>