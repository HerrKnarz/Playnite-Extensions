<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:converters="clr-namespace:KNARZhelper.Controls"
                    mc:Ignorable="d">
    <DataTemplate x:Key="FolderConfigTemplate">
        <DataTemplate.Resources>
            <ResourceDictionary>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground"
                            Value="{DynamicResource TextBrush}"
                            d:Value="{DynamicResource KNARZDummyBrushBlack}" />
                    <Setter Property="VerticalAlignment"
                            Value="Top" />
                    <Setter Property="TextWrapping"
                            Value="Wrap" />
                </Style>

                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/ScreenshotUtilitiesLocalProvider;component/Shared/Controls/CommonStyles.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </DataTemplate.Resources>
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Margin="0, 0, 0, 5">
                <Button Content="&#xec53;"
                        DockPanel.Dock="Right"
                        Style="{DynamicResource KNARZIconButton}"
                        Margin="10, 0, 0, 0"
                        VerticalAlignment="Top"
                        ToolTip="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonRemove}"
                        d:ToolTip=""
                        Command="{Binding Path=DataContext.RemoveFolderConfigCommand, ElementName=ConfigDock}"
                        CommandParameter="{Binding}" />
                <Button Content="&#xec55;"
                        DockPanel.Dock="Right"
                        Style="{DynamicResource KNARZIconButton}"
                        VerticalAlignment="Top"
                        ToolTip="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsButtonEdit}"
                        d:ToolTip=""
                        Command="{Binding Path=DataContext.EditFolderConfigCommand, ElementName=ConfigDock}"
                        CommandParameter="{Binding}" />
                <CheckBox Content="{Binding Name}"
                          d:Content="Name"
                          IsChecked="{Binding Active}"
                          DockPanel.Dock="Left"
                          Margin="0, 0, 0, 10"
                          FontWeight="Bold"
                          FontSize="{DynamicResource FontSizeLarge}"
                          d:FontSize="16" />
            </DockPanel>

            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigPath}"
                       Grid.Row="1"
                       Grid.Column="0" />
            <DockPanel Grid.Row="1"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Margin="10, 0, 0, 5"
                       VerticalAlignment="Top">
                <Button Content="&#xec5b;"
                        Style="{DynamicResource KNARZIconButton}"
                        Margin="10, 0, 0, 0"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Command="{Binding OpenResolvedFolderCommand}" />
                <TextBlock Text="{Binding Path}"
                           DockPanel.Dock="Left" />
            </DockPanel>

            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesLocalProviderSettingsFolderConfigFileMask}"
                       Grid.Row="2"
                       Grid.Column="0" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Margin="10, 0, 0, 0"
                       Text="{Binding FileMask}" />
        </Grid>
    </DataTemplate>
</ResourceDictionary>