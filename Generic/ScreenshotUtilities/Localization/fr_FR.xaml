    <sys:String x:Key="LOCScreenshotUtilitiesName">Utilitaires de capture d'écran</sys:String>

    <sys:String x:Key="LOC_ScreenshotUtilities_ControlLabel">Captures d'écran </sys:String>

    <sys:String x:Key="LOCScreenshotUtilitiesDialogResetScreenshots">Do you really want to reset the screenshots? This will delete all screenshots from the selected game(s) and loads them again from their sources.</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesDialogResetScreenshotsAll">Do you really want to reset the screenshots? This will delete all screenshots from all games in your library and loads them again from their sources. This can take some time for big libraries.</sys:String>
