    <sys:String x:Key="LOCScreenshotUtilitiesMenuOpenInBrowser">Ouvrir dans le navigateur</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesMenuOpenInFullScreen">Ouvrir en mode plein écran</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesMenuRefreshFrom">Rafraîchir les captures d'écran de</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesMenuRefreshScreenshots">Rafraîchir toutes les captures d'écran</sys:String>
