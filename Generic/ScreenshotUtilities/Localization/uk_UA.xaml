    <sys:String x:Key="LOCScreenshotUtilitiesMenuOpenInBrowser">Відкрити в браузері</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesMenuOpenInFullScreen">Відкрити в повноекранному режимі</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesMenuRefreshFrom">Оновити знімки екрану з</sys:String>
