    <sys:String x:Key="LOCScreenshotUtilitiesMenuResetFromAll">Reset screenshots for all games from</sys:String>
    <sys:String x:Key="LOCScreenshotUtilitiesMenuResetScreenshots">Скинути знімки екрану</sys:String>
