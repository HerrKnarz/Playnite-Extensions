<UserControl x:Class="ScreenshotUtilities.Views.ScreenshotUtilitiesSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:screenshotutilities="clr-namespace:ScreenshotUtilities"
             xmlns:models="clr-namespace:ScreenshotUtilities.Models"
             xmlns:c="clr-namespace:KNARZHelper.Controls"
             d:DataContext="{d:DesignInstance Type=screenshotutilities:ScreenshotUtilitiesSettingsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="950"
             d:DesignWidth="700"
             d:Background="LightGray"
             Padding="15, 15, 15, 15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <d:ResourceDictionary Source="/ScreenshotUtilities;component/Localization/en_US.xaml" />
                <ResourceDictionary Source="/ScreenshotUtilities;component/Shared/Controls/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Margin="0, 0, 0, 10"
                    Padding="15, 10, 15, 15"
                    CornerRadius="5"
                    BorderBrush="{StaticResource NormalBorderBrush}"
                    d:BorderBrush="WhiteSmoke"
                    BorderThickness="2">
                <StackPanel>
                    <Label Content="General"
                           DockPanel.Dock="Top"
                           FontSize="{StaticResource FontSizeLarge}"
                           d:FontSize="15"
                           FontWeight="Bold"
                           Margin="0, 0, 0, 15" />

                    <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsAspectRatio}">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding Settings.AspectWidth}"
                                     Width="40"
                                     Margin="0,0,5,0" />
                            <Label Content=":"
                                   Margin="0,0,5,0" />
                            <TextBox Text="{Binding Settings.AspectHeight}"
                                     Width="40" />
                        </StackPanel>
                    </c:SettingsOption>

                    <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsThumbnailHeight}">
                        <TextBox Text="{Binding Settings.ThumbnailHeight}"
                                 Width="40" />
                    </c:SettingsOption>

                    <CheckBox IsChecked="{Binding Settings.DisplayViewerControl}"
                              Content="{DynamicResource LOCScreenshotUtilitiesSettingsDisplayViewerControl}"
                              Margin="0, 0, 0, 15" />

                    <CheckBox IsChecked="{Binding Settings.DisplayButtonControl}"
                              Content="{DynamicResource LOCScreenshotUtilitiesSettingsDisplayButtonControl}" />
                </StackPanel>
            </Border>

            <Border DockPanel.Dock="Top"
                    Margin="0, 0, 0, 10"
                    Padding="15, 10, 15, 15"
                    MinHeight="300"
                    CornerRadius="5"
                    BorderBrush="{StaticResource NormalBorderBrush}"
                    d:BorderBrush="WhiteSmoke"
                    BorderThickness="2">
                <DockPanel>
                    <Label Content="Provider Settings"
                           DockPanel.Dock="Top"
                           FontSize="{StaticResource FontSizeLarge}"
                           d:FontSize="15"
                           FontWeight="Bold"
                           Margin="0, 0, 0, 15" />

                    <DockPanel DockPanel.Dock="Top">
                        <ListBox Name="LbProviderSettings"
                                 DockPanel.Dock="Left"
                                 MinWidth="150"
                                 VerticalAlignment="Stretch"
                                 ItemsSource="{Binding Settings.ProviderSettings}"
                                 SelectedValuePath="Value"
                                 SelectedItem="{Binding SelectedProviderSetting}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Key}"
                                               Margin="5" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel DockPanel.Dock="Right"
                                    Margin="15, 0, 0, 0"
                                    d:DataContext="{d:DesignInstance Type=models:ProviderSettings}"
                                    DataContext="{Binding SelectedValue, ElementName=LbProviderSettings}"
                                    VerticalAlignment="Top">
                            <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsSortOrder}"
                                              Description="{DynamicResource LOCScreenshotUtilitiesSettingsSortOrderDescription}">
                                <TextBox Text="{Binding SortOrder}"
                                         Width="40"
                                         HorizontalContentAlignment="Right" />
                            </c:SettingsOption>

                            <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsPriority}"
                                              Description="{DynamicResource LOCScreenshotUtilitiesSettingsPriorityDescription}">
                                <TextBox Text="{Binding Priority}"
                                         Width="40"
                                         HorizontalContentAlignment="Right" />
                            </c:SettingsOption>

                            <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsFetchMode}"
                                              Description="{DynamicResource LOCScreenshotUtilitiesSettingsFetchModeDescription}">
                                <ComboBox ItemsSource="{Binding Path=ScreenshotFetchModesWithCaptions}"
                                          DisplayMemberPath="Value"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding Path=FetchMode}"
                                          MinWidth="200" />
                            </c:SettingsOption>

                            <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsDaysRefresh}"
                                              Description="{DynamicResource LOCScreenshotUtilitiesSettingsDaysRefreshDescription}">
                                <TextBox Text="{Binding DaysUntilRefresh}"
                                         Width="40"
                                         HorizontalContentAlignment="Right" />
                            </c:SettingsOption>

                            <c:SettingsOption Title="{DynamicResource LOCScreenshotUtilitiesSettingsTagWhenHavingScreenshots}"
                                              Description="{DynamicResource LOCScreenshotUtilitiesSettingsTagWhenHavingScreenshotsDescription}">
                                <DockPanel>
                                    <Button Content="{DynamicResource LOCScreenshotUtilitiesSettingsSelect}"
                                            DockPanel.Dock="Right"
                                            Margin="10, 0, 0, 0"
                                            Command="{Binding AddTagToAddWhenHavingScreenshotsCommand}"
                                            CommandParameter="{Binding TagWhenHavingScreenshots}" />
                                    <TextBox Text="{Binding TagWhenHavingScreenshots}" />
                                </DockPanel>
                            </c:SettingsOption>

                            <CheckBox IsChecked="{Binding DownloadAutomatically}"
                                      Margin="0, 0, 0, 5"
                                      Content="{DynamicResource LOCScreenshotUtilitiesSettingsAutomaticDownload}" />
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsAutomaticDownloadDescription}"
                                       Style="{StaticResource SettingsDescription}"
                                       Margin="0, 0, 0, 15" />

                            <CheckBox IsChecked="{Binding AlwaysCreateThumbnails}"
                                      Margin="0, 0, 0, 5"
                                      Content="{DynamicResource LOCScreenshotUtilitiesSettingsAlwaysCreateThumbnails}" />
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsAlwaysCreateThumbnailsDescription}"
                                       Style="{StaticResource SettingsDescription}" />
                        </StackPanel>
                    </DockPanel>
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    MinHeight="150"
                    Margin="0, 0, 0, 10"
                    Padding="15, 10, 15, 15"
                    CornerRadius="5"
                    BorderBrush="{StaticResource NormalBorderBrush}"
                    d:BorderBrush="WhiteSmoke"
                    BorderThickness="2">
                <DockPanel>
                    <Label Content="Download Filter"
                           DockPanel.Dock="Top"
                           FontSize="{StaticResource FontSizeLarge}"
                           d:FontSize="15"
                           Margin="0, 0, 0, 5"
                           FontWeight="Bold" />
                    <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsDownloadFilterInfo}"
                               Style="{StaticResource SettingsDescription}"
                               Margin="0, 0, 0, 15"
                               DockPanel.Dock="Top" />
                    <DockPanel DockPanel.Dock="Bottom"
                               LastChildFill="False">
                        <Button Content="&#xec3e; &#xef36;"
                                Style="{StaticResource KNARZIconButton}"
                                ToolTip="{DynamicResource LOCCategoryLabel}"
                                Margin="0,0,10,0"
                                Command="{Binding AddCategoryCommand}"
                                DockPanel.Dock="Left" />
                        <Button Content="&#xec3e; &#xf004;"
                                Style="{StaticResource KNARZIconButton}"
                                ToolTip="{DynamicResource LOCTagLabel}"
                                Margin="0,0,10,0"
                                Command="{Binding AddTagCommand}"
                                DockPanel.Dock="Left" />
                        <Button Content="&#xec53;"
                                Style="{StaticResource KNARZIconButton}"
                                ToolTip="{DynamicResource LOCRemoveTitle}"
                                Margin="0,0,0,0"
                                Command="{Binding RemoveFromListCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=LbDownloadFilter}"
                                DockPanel.Dock="Left" />
                    </DockPanel>
                    <ListBox Name="LbDownloadFilter"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Stretch"
                             Margin="0, 0, 0, 10"
                             MinHeight="100"
                             DockPanel.Dock="Top"
                             VerticalAlignment="Stretch"
                             SelectionMode="Extended"
                             ItemsSource="{Binding Settings.DownloadFilter}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TypeAndName}"
                                           Margin="5" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </DockPanel>
    </ScrollViewer>
</UserControl>