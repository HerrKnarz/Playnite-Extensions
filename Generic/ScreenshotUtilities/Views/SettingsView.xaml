<UserControl x:Class="ScreenshotUtilities.Views.ScreenshotUtilitiesSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:screenshotutilities="clr-namespace:ScreenshotUtilities"
             xmlns:models="clr-namespace:ScreenshotUtilities.Models"
             d:DataContext="{d:DesignInstance Type=screenshotutilities:ScreenshotUtilitiesSettingsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="950"
             d:DesignWidth="700"
             d:Background="LightGray"
             Padding="15, 15, 15, 15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <d:ResourceDictionary Source="/ScreenshotUtilities;component/Localization/en_US.xaml" />
                <ResourceDictionary Source="/ScreenshotUtilities;component/Shared/Controls/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Margin="0, 0, 0, 10"
                    Padding="15, 10, 15, 15"
                    CornerRadius="5"
                    BorderBrush="{StaticResource NormalBorderBrush}"
                    d:BorderBrush="WhiteSmoke"
                    BorderThickness="2">
                <DockPanel>
                    <Label Content="General"
                           DockPanel.Dock="Top"
                           FontSize="{StaticResource FontSizeLarge}"
                           d:FontSize="15"
                           FontWeight="Bold"
                           Margin="0, 0, 0, 15" />

                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsAspectRatio}"
                               Grid.Column="0"
                               Grid.Row="0"
                               Margin="0, 0, 0, 10" />

                        <StackPanel Orientation="Horizontal"
                                    Grid.Column="1"
                                    Grid.Row="0"
                                    Margin="10, 0, 0, 10">
                            <TextBox Text="{Binding Settings.AspectWidth}"
                                     Width="40"
                                     Margin="0,0,5,0" />
                            <Label Content=":"
                                   Margin="0,0,5,0" />
                            <TextBox Text="{Binding Settings.AspectHeight}"
                                     Width="40" />
                        </StackPanel>

                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsThumbnailHeight}"
                               Grid.Column="0"
                               Grid.Row="1"
                               Margin="0, 0, 0, 10" />
                        <TextBox Text="{Binding Settings.ThumbnailHeight}"
                                 Width="40"
                                 Grid.Column="1"
                                 Grid.Row="1"
                                 Margin="10, 0, 0, 10"
                                 HorizontalAlignment="Left" />
                    </Grid>

                    <CheckBox IsChecked="{Binding Settings.DisplayViewerControl}"
                              Content="{DynamicResource LOCScreenshotUtilitiesSettingsDisplayViewerControl}"
                              DockPanel.Dock="Top"
                              Margin="0, 0, 0, 10" />

                    <CheckBox IsChecked="{Binding Settings.DisplayButtonControl}"
                              Content="{DynamicResource LOCScreenshotUtilitiesSettingsDisplayButtonControl}"
                              DockPanel.Dock="Top"
                              Margin="0, 0, 0, 10" />
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Top"
                    Margin="0, 0, 0, 10"
                    Padding="15, 10, 15, 15"
                    MinHeight="300"
                    CornerRadius="5"
                    BorderBrush="{StaticResource NormalBorderBrush}"
                    d:BorderBrush="WhiteSmoke"
                    BorderThickness="2">
                <DockPanel>
                    <Label Content="Provider Settings"
                           DockPanel.Dock="Top"
                           FontSize="{StaticResource FontSizeLarge}"
                           d:FontSize="15"
                           FontWeight="Bold"
                           Margin="0, 0, 0, 15" />

                    <DockPanel DockPanel.Dock="Top">
                        <ListBox Name="LbProviderSettings"
                                 DockPanel.Dock="Left"
                                 MinWidth="150"
                                 VerticalAlignment="Stretch"
                                 ItemsSource="{Binding Settings.ProviderSettings}"
                                 SelectedValuePath="Value"
                                 SelectedItem="{Binding SelectedProviderSetting}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Key}"
                                               Margin="5" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel DockPanel.Dock="Right"
                                    Margin="15, 0, 0, 0"
                                    d:DataContext="{d:DesignInstance Type=models:ProviderSettings}"
                                    DataContext="{Binding SelectedValue, ElementName=LbProviderSettings}"
                                    VerticalAlignment="Top">
                            <DockPanel>
                                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsSortOrder}" />
                                <TextBox Text="{Binding SortOrder}"
                                         Width="40"
                                         Margin="10, 0, 0, 0"
                                         HorizontalAlignment="Right"
                                         HorizontalContentAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsSortOrderDescription}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       d:FontSize="12"
                                       Foreground="{StaticResource TextBrushDarker}"
                                       d:Foreground="DarkSlateGray"
                                       Margin="0, 0, 0, 15" />

                            <DockPanel>
                                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsPriority}" />
                                <TextBox Text="{Binding Priority}"
                                         Width="40"
                                         Margin="10, 0, 0, 0"
                                         DockPanel.Dock="Right"
                                         HorizontalAlignment="Right"
                                         HorizontalContentAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsPriorityDescription}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       d:FontSize="12"
                                       Foreground="{StaticResource TextBrushDarker}"
                                       d:Foreground="DarkSlateGray"
                                       Margin="0, 0, 0, 15" />

                            <DockPanel>
                                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsFetchMode}" />
                                <ComboBox ItemsSource="{Binding Path=ScreenshotFetchModesWithCaptions}"
                                          DisplayMemberPath="Value"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding Path=FetchMode}"
                                          Margin="10, 0, 0, 0"
                                          MinWidth="200"
                                          HorizontalAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsFetchModeDescription}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       d:FontSize="12"
                                       Foreground="{StaticResource TextBrushDarker}"
                                       d:Foreground="DarkSlateGray"
                                       Margin="0, 0, 0, 15" />

                            <DockPanel>
                                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsDaysRefresh}" />
                                <TextBox Text="{Binding DaysUntilRefresh}"
                                         Width="40"
                                         Margin="10, 0, 0, 0"
                                         HorizontalAlignment="Right"
                                         HorizontalContentAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsDaysRefreshDescription}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       d:FontSize="12"
                                       Foreground="{StaticResource TextBrushDarker}"
                                       d:Foreground="DarkSlateGray"
                                       Margin="0, 0, 0, 15" />

                            <DockPanel>
                                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsTagWhenHavingScreenshots}" />                                    
                                    <Button Content="{DynamicResource LOCScreenshotUtilitiesSettingsSelect}"
                                            DockPanel.Dock="Right"
                                            Margin="10, 0, 0, 0"
                                            Command="{Binding AddTagToAddWhenHavingScreenshotsCommand}"
                                            CommandParameter="{Binding TagWhenHavingScreenshots}" />
                                <TextBox Text="{Binding TagWhenHavingScreenshots}"
                                         Margin="10, 0, 0, 0" />
                            </DockPanel>
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsTagWhenHavingScreenshotsDescription}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       d:FontSize="12"
                                       Foreground="{StaticResource TextBrushDarker}"
                                       d:Foreground="DarkSlateGray"
                                       Margin="0, 0, 0, 15" />

                                    <CheckBox IsChecked="{Binding DownloadAutomatically}"
                                              Margin="0, 0, 0, 5"
                                              Content="{DynamicResource LOCScreenshotUtilitiesSettingsAutomaticDownload}" />
                                    <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsAutomaticDownloadDescription}"
                                               TextWrapping="Wrap"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               d:FontSize="12"
                                               Foreground="{StaticResource TextBrushDarker}"
                                               d:Foreground="DarkSlateGray"
                                               Margin="0, 0, 0, 15" />

                            <CheckBox IsChecked="{Binding AlwaysCreateThumbnails}"
                                      Margin="0, 0, 0, 5"
                                      Content="{DynamicResource LOCScreenshotUtilitiesSettingsAlwaysCreateThumbnails}" />
                            <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsAlwaysCreateThumbnailsDescription}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       d:FontSize="12"
                                       Foreground="{StaticResource TextBrushDarker}"
                                       d:Foreground="DarkSlateGray" />

                        </StackPanel>
                    </DockPanel>
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    MinHeight="150"
                    Margin="0, 0, 0, 10"
                    Padding="15, 10, 15, 15"
                    CornerRadius="5"
                    BorderBrush="{StaticResource NormalBorderBrush}"
                    d:BorderBrush="WhiteSmoke"
                    BorderThickness="2">
                <DockPanel>
                    <Label Content="Download Filter"
                           DockPanel.Dock="Top"
                           FontSize="{StaticResource FontSizeLarge}"
                           d:FontSize="15"
                           FontWeight="Bold"
                           Margin="0, 0, 0, 5" />
                    <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsDownloadFilterInfo}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeSmall}"
                               d:FontSize="12"
                               Foreground="{StaticResource TextBrushDarker}"
                               d:Foreground="DarkSlateGray"
                               Margin="0, 0, 0, 15"
                               DockPanel.Dock="Top" />
                    <DockPanel DockPanel.Dock="Bottom"
                               LastChildFill="False">
                        <Button Content="&#xec3e; &#xef36;"
                                Style="{StaticResource KNARZIconButton}"
                                ToolTip="{DynamicResource LOCCategoryLabel}"
                                Margin="0,0,10,0"
                                Command="{Binding AddCategoryCommand}"
                                DockPanel.Dock="Left" />
                        <Button Content="&#xec3e; &#xf004;"
                                Style="{StaticResource KNARZIconButton}"
                                ToolTip="{DynamicResource LOCTagLabel}"
                                Margin="0,0,10,0"
                                Command="{Binding AddTagCommand}"
                                DockPanel.Dock="Left" />
                        <Button Content="&#xec53;"
                                Style="{StaticResource KNARZIconButton}"
                                ToolTip="{DynamicResource LOCRemoveTitle}"
                                Margin="0,0,0,0"
                                Command="{Binding RemoveFromListCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=LbDownloadFilter}"
                                DockPanel.Dock="Left" />
                    </DockPanel>
                    <ListBox Name="LbDownloadFilter"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Stretch"
                             Margin="0, 0, 0, 10"
                             MinHeight="100"
                             DockPanel.Dock="Top"
                             VerticalAlignment="Stretch"
                             SelectionMode="Extended"
                             ItemsSource="{Binding Settings.DownloadFilter}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TypeAndName}"
                                           Margin="5" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </DockPanel>
    </ScrollViewer>
</UserControl>