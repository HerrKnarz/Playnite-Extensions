<UserControl x:Class="ScreenshotUtilities.Views.ScreenshotUtilitiesSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:screenshotutilities="clr-namespace:ScreenshotUtilities"
             xmlns:models="clr-namespace:ScreenshotUtilities.Models"
             d:DataContext="{d:DesignInstance Type=screenshotutilities:ScreenshotUtilitiesSettingsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="600"
             d:Background="AliceBlue">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <d:ResourceDictionary Source="/ScreenshotUtilities;component/Localization/en_US.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer>
        <DockPanel Margin="15">
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsAspectRatio}"
                       Grid.Column="0"
                       Grid.Row="0"
                       Margin="0, 0, 0, 10" />

                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            Grid.Row="0"
                            Margin="10, 0, 0, 10">
                    <TextBox Text="{Binding Settings.AspectWidth}"
                             Width="40"
                             Margin="0,0,5,0" />
                    <Label Content=":"
                           Margin="0,0,5,0" />
                    <TextBox Text="{Binding Settings.AspectHeight}"
                             Width="40" />
                </StackPanel>

                <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsThumbnailHeight}"
                       Grid.Column="0"
                       Grid.Row="1"
                       Margin="0, 0, 0, 10" />
                <TextBox Text="{Binding Settings.ThumbnailHeight}"
                         Width="40"
                         Grid.Column="1"
                         Grid.Row="1"
                         Margin="10, 0, 0, 10"
                         HorizontalAlignment="Left" />
            </Grid>

            <CheckBox IsChecked="{Binding Settings.DisplayViewerControl}"
                      Content="{DynamicResource LOCScreenshotUtilitiesSettingsDisplayViewerControl}"
                      DockPanel.Dock="Top"
                      Margin="0, 0, 0, 10" />

            <CheckBox IsChecked="{Binding Settings.DisplayButtonControl}"
                      Content="{DynamicResource LOCScreenshotUtilitiesSettingsDisplayButtonControl}"
                      DockPanel.Dock="Top"
                      Margin="0, 0, 0, 10" />

            <DockPanel DockPanel.Dock="Bottom"
                       Height="250"
                       VerticalAlignment="Bottom">
                <DockPanel DockPanel.Dock="Bottom"
                           LastChildFill="False">
                    <Button Content="&#xec3e; &#xef36;"
                            FontFamily="{DynamicResource FontIcoFont}"
                            ToolTip="{DynamicResource LOCCategoryLabel}"
                            Margin="0,0,10,0"
                            Command="{Binding AddCategoryCommand}"
                            DockPanel.Dock="Left" />
                    <Button Content="&#xec3e; &#xf004;"
                            FontFamily="{DynamicResource FontIcoFont}"
                            ToolTip="{DynamicResource LOCTagLabel}"
                            Margin="0,0,10,0"
                            Command="{Binding AddTagCommand}"
                            DockPanel.Dock="Left" />
                    <Button Content="&#xec53;"
                            FontFamily="{DynamicResource FontIcoFont}"
                            ToolTip="{DynamicResource LOCRemoveTitle}"
                            Margin="0,0,0,0"
                            Command="{Binding RemoveFromListCommand}"
                            CommandParameter="{Binding SelectedItems, ElementName=LbDownloadFilter}"
                            DockPanel.Dock="Left" />
                </DockPanel>

                <DockPanel DockPanel.Dock="Top"
                           Margin="0, 0, 0, 10">
                    <ListBox Name="LbDownloadFilter"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Stretch"
                             Width="300"
                             DockPanel.Dock="Left"
                             VerticalAlignment="Stretch"
                             SelectionMode="Extended"
                             ItemsSource="{Binding Settings.DownloadFilter}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TypeAndName}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="{DynamicResource LOCScreenshotUtilitiesSettingsDownloadFilterInfo}"
                               TextWrapping="Wrap"
                               Margin="10, 0, 0, 0"
                               MinWidth="200"
                               DockPanel.Dock="Right" />
                </DockPanel>
            </DockPanel>

            <GroupBox Header="Provider Settings"
                      DockPanel.Dock="Top"
                      Margin="0, 0, 0, 10"
                      MinHeight="300">
                <DockPanel Margin="5">
                    <ListBox Name="LbProviderSettings"
                             DockPanel.Dock="Left"
                             MinWidth="150"
                             VerticalAlignment="Stretch"
                             ItemsSource="{Binding Settings.ProviderSettings}"
                             SelectedValuePath="Value"
                             SelectedItem="{Binding SelectedProviderSetting}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Key}"
                                           Margin="5" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Margin="10, 0, 0, 0"
                          d:DataContext="{d:DesignInstance Type=models:ProviderSettings}"
                          DataContext="{Binding SelectedValue, ElementName=LbProviderSettings}"
                          VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsSortOrder}"
                               Grid.Column="0"
                               Grid.Row="0"
                               Margin="0, 0, 0, 10" />
                        <TextBox Text="{Binding SortOrder}"
                                 Grid.Column="1"
                                 Grid.Row="0"
                                 Width="40"
                                 Margin="10,0,0,10"
                                 HorizontalAlignment="Left" />

                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsPriority}"
                               Grid.Column="0"
                               Grid.Row="1"
                               Margin="0, 0, 0, 10" />
                        <TextBox Text="{Binding Priority}"
                                 Grid.Column="1"
                                 Grid.Row="1"
                                 Width="40"
                                 Margin="10,0,0,10"
                                 HorizontalAlignment="Left" />

                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsFetchMode}"
                               Grid.Column="0"
                               Grid.Row="2"
                               Margin="0, 0, 0, 10" />
                        <ComboBox Grid.Column="1"
                                  Grid.Row="2"
                                  ItemsSource="{Binding Path=ScreenshotFetchModesWithCaptions}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding Path=FetchMode}"
                                  Margin="10,0,0,10"
                                  HorizontalAlignment="Stretch" />

                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsDaysRefresh}"
                               Grid.Column="0"
                               Grid.Row="3"
                               Margin="0, 0, 0, 10" />
                        <TextBox Text="{Binding DaysUntilRefresh}"
                                 Grid.Column="1"
                                 Grid.Row="3"
                                 Width="40"
                                 Margin="10,0,0,10"
                                 HorizontalAlignment="Left" />

                        <Label Content="{DynamicResource LOCScreenshotUtilitiesSettingsTagWhenHavingScreenshots}"
                               Grid.Column="0"
                               Grid.Row="4"
                               Margin="0, 0, 0, 10" />
                        <DockPanel  Grid.Column="1"
                                    Grid.Row="4"
                                    Margin="10,0,0,10">
                            <Button Content="{DynamicResource LOCScreenshotUtilitiesSettingsSelect}"
                                    DockPanel.Dock="Right"
                                    Margin="10,0,0,0"
                                    Command="{Binding AddTagToAddWhenHavingScreenshotsCommand}"
                                    CommandParameter="{Binding TagWhenHavingScreenshots}" />
                            <TextBox Text="{Binding TagWhenHavingScreenshots}"
                                     DockPanel.Dock="Left" />
                        </DockPanel>

                        <CheckBox IsChecked="{Binding DownloadAutomatically}"
                                  Content="{DynamicResource LOCScreenshotUtilitiesSettingsAutomaticDownload}"
                                  Grid.ColumnSpan="2"
                                  Grid.Row="5"
                                  Margin="0, 0, 0, 10" />

                        <CheckBox IsChecked="{Binding AlwaysCreateThumbnails}"
                                  Content="{DynamicResource LOCScreenshotUtilitiesSettingsAlwaysCreateThumbnails}"
                                  Grid.ColumnSpan="2"
                                  Grid.Row="6"
                                  Margin="0" />
                    </Grid>
                </DockPanel>
            </GroupBox>
        </DockPanel>
    </ScrollViewer>
</UserControl>