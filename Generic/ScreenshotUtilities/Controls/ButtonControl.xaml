<PluginUserControl x:Class="ScreenshotUtilities.Controls.ButtonControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:ScreenshotUtilities.Controls"
                   xmlns:viewmodels="clr-namespace:ScreenshotUtilities.ViewModels"
                   d:DataContext="{d:DesignInstance Type=viewmodels:ButtonControlViewModel}"
                   mc:Ignorable="d"
                   d:DesignHeight="40"
                   d:DesignWidth="40">
    <PluginUserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ScreenshotUtilities;component/Shared/Controls/CommonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </PluginUserControl.Resources>
    <Button Name="PART_PluginButton"
            Command="{Binding OpenViewerCommand}"
            Content="&#xef4b;"
            Style="{StaticResource KNARZIconButton}"
            FontSize="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FontSize}" />
</PluginUserControl>